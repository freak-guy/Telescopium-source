// ===============
// Telescopium Liquid Glass Navigation
// ===============

#header
  position: fixed
  top: 0
  left: 0
  right: 0
  z-index: 100
  height: 60px
  // Darker liquid glass for fixed nav — stays readable against scrolled content
  background: linear-gradient(180deg, rgba(8, 11, 20, 0.88), rgba(8, 11, 20, 0.78))
  backdrop-filter: blur(24px) saturate(180%)
  -webkit-backdrop-filter: blur(24px) saturate(180%)
  border-bottom: 1px solid rgba(255, 255, 255, 0.1)
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.12),
    0 1px 0 rgba(0, 0, 0, 0.3),
    0 16px 48px rgba(0, 0, 0, 0.35)
  transition: background 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease

#header-outer
  height: 100%
  position: relative
  display: flex
  align-items: center
  justify-content: space-between

#header-inner
  display: flex
  align-items: center
  justify-content: space-between
  width: 100%

#header-title
  display: flex
  align-items: center
  flex-shrink: 0

// Hide old banner
#banner
  display: none

$logo-text
  text-decoration: none
  color: #F8FAFC
  font-weight: 600
  letter-spacing: 2.5px
  transition: color 0.25s ease, text-shadow 0.25s ease

#logo
  @extend $logo-text
  font-size: 18px
  line-height: 1
  &:hover
    color: #60A5FA
    text-shadow: 0 0 16px rgba(96, 165, 250, 0.45)

#subtitle
  display: none

#subtitle-wrap
  display: none

// ===============
// Main Navigation Links
// ===============
#main-nav
  display: flex
  align-items: center
  gap: 2px

$nav-link
  color: #94A3B8
  text-decoration: none
  font-size: 13.5px
  font-weight: 450
  letter-spacing: 0.4px
  padding: 7px 14px
  border-radius: 8px
  transition: color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease
  display: block
  &:hover
    color: #F8FAFC
    background: rgba(255, 255, 255, 0.06)
    box-shadow: 0 0 18px rgba(59, 130, 246, 0.12)

.nav-icon
  @extend $nav-link
  text-align: center
  font-size: 16px
  width: 16px
  height: 16px

.main-nav-link
  @extend $nav-link
  font-weight: 450
  @media mq-mobile
    display: none

#main-nav-toggle
  display: none
  color: #94A3B8
  font-size: 20px
  cursor: pointer
  padding: 8px 12px
  border-radius: 8px
  transition: color 0.2s ease, background 0.2s ease
  @media mq-mobile
    display: block
  &:hover
    color: #F8FAFC
    background: rgba(255, 255, 255, 0.06)

#sub-nav
  display: flex
  align-items: center
  gap: 2px

// ===============
// Search Form
// ===============
#search-form-wrap
  position: absolute
  top: 12px
  width: 200px
  height: 36px
  right: -200px
  opacity: 0
  transition: 0.25s ease-out
  &.on
    opacity: 1
    right: 0
  @media mq-mobile
    width: 100%
    right: -100%

.search-form
  position: absolute
  top: 0
  left: 0
  right: 0
  background: linear-gradient(135deg, rgba(17, 24, 39, 0.95), rgba(17, 24, 39, 0.85))
  backdrop-filter: blur(20px) saturate(180%)
  -webkit-backdrop-filter: blur(20px) saturate(180%)
  padding: 5px 15px
  border-radius: 18px
  border: 1px solid rgba(255, 255, 255, 0.14)
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.1),
    0 12px 40px rgba(0, 0, 0, 0.4)

.search-form-input
  border: none
  background: none
  color: #F8FAFC
  width: 100%
  font: 13px font-sans
  outline: none
  &::-webkit-search-results-decoration
  &::-webkit-search-cancel-button
    -webkit-appearance: none
  &::placeholder
    color: #64748B

.search-form-submit
  position: absolute
  top: 50%
  right: 10px
  margin-top: -7px
  font: 13px font-icon
  border: none
  background: none
  color: #64748B
  cursor: pointer
  &:hover, &:focus
    color: #94A3B8

// Offset body for fixed header
body
  padding-top: 60px

@media mq-mobile
  body
    padding-top: 56px

  #header
    height: 56px
