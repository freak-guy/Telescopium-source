// ===============
// Telescopium Footer
// ===============

#footer
  background: transparent
  padding: 64px 0 44px
  border-top: 1px solid rgba(148, 163, 184, 0.10)
  color: #94A3B8
  text-align: center
  a
    color: #CBD5E1
    text-decoration: none
    transition: color 0.2s ease
    &:hover
      color: #93C5FD
      text-decoration: none

#footer-info
  line-height: 2.1em
  font-size: 0.85em
  color: #94A3B8
  letter-spacing: 0.3px
