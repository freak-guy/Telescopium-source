// ===============
// Telescopium Footer
// ===============

#footer
  background: transparent
  padding: 64px 0 44px
  border-top: 1px solid rgba(255, 255, 255, 0.05)
  color: #64748B
  text-align: center
  a
    color: #94A3B8
    text-decoration: none
    transition: color 0.2s ease
    &:hover
      color: #60A5FA
      text-decoration: none

#footer-info
  line-height: 2.1em
  font-size: 0.85em
  color: #64748B
  letter-spacing: 0.3px
