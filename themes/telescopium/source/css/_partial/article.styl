// ===============
// Telescopium Liquid Glass Article Cards & Reading
// ===============

.article
  margin: block-margin 0

// Liquid glass card — inherits $block, adds article-specific refinements
.article-inner
  @extend $block
  overflow: hidden
  border-radius: 22px
  transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease

.article:hover .article-inner
  transform: translateY(-3px)
  border-color: rgba(147, 197, 253, 0.36)
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.08),
    0 32px 96px rgba(15, 23, 42, 0.5),
    0 0 0 1px rgba(59, 130, 246, 0.1),
    0 0 48px rgba(59, 130, 246, 0.08)

.article-meta
  clearfix()
  padding: 24px article-padding 0

.article-date
  @extend $block-caption
  float: left
  color: #94A3B8
  font-size: 0.78em

.article-category
  float: left
  line-height: 1em
  color: #94A3B8
  margin-left: 8px
  font-size: 0.85em
  &:before
    content: "\2022"

.article-category-link
  @extend $block-caption
  margin: 0 12px 1em
  color: #94A3B8

.article-header
  padding: 20px article-padding 0

.article-title
  text-decoration: none
  font-size: 1.75em
  font-weight: 700
  color: #F8FAFC
  line-height: 1.25
  letter-spacing: -0.01em
  transition: color 0.2s ease
  a&:hover
    color: #60A5FA

// ===============
// Article Entry — Reading Experience (Brighter)
// ===============
.article-entry
  @extend $base-style
  clearfix()
  color: #DDE6F3
  padding: 0 article-padding
  max-width: 820px

  // Paragraphs
  p
    line-height: 1.9em
    margin: 1.3em 0
    color: #CBD5E1

  // Heading hierarchy — clear, scannable, properly spaced
  h1, h2, h3, h4, h5, h6
    font-weight: 700
    color: #F8FAFC
    line-height: 1.25
    margin: 1.8em 0 0.6em

  h1
    font-size: 1.9em
    padding-bottom: 0.35em
    border-bottom: 1px solid rgba(255, 255, 255, 0.1)

  h2
    font-size: 1.5em

  h3
    font-size: 1.25em

  h4
    font-size: 1.1em

  h5, h6
    font-size: 1em
    color: #94A3B8

  // Links
  a
    color: #93C5FD
    text-decoration: none
    transition: color 0.2s ease
    &:hover
      color: #BAE6FD
      text-decoration: underline

  // Lists
  ul, ol, dl
    margin-top: 1em
    margin-bottom: 1em
    line-height: 1.85em

  // Images
  img, video
    max-width: 100%
    height: auto
    display: block
    margin: 1.8em auto
    border-radius: 10px

  iframe
    border: none

  // Tables
  table
    width: 100%
    border-collapse: collapse
    border-spacing: 0
    font-size: 0.95em
    margin: 1.5em 0

  th
    font-weight: 600
    border-bottom: 2px solid rgba(255, 255, 255, 0.12)
    padding: 10px 0 8px
    color: #F8FAFC

  td
    border-bottom: 1px solid rgba(255, 255, 255, 0.06)
    padding: 10px 0

  // Blockquote — brighter accent
  blockquote
    font-family: font-serif
    margin: 1.8em 0
    padding: 18px 24px
    border-left: 3px solid rgba(96, 165, 250, 0.75)
    background: rgba(59, 130, 246, 0.10)
    border-radius: 0 12px 12px 0
    color: #E2E8F0
    footer
      font-size: font-size
      margin: 0.8em 0 0
      font-family: font-sans
      cite
        &:before
          content: "—"
          padding: 0 0.5em

  .pullquote
    text-align: left
    width: 45%
    margin: 0
    &.left
      margin-left: 0.5em
      margin-right: 1em
    &.right
      margin-right: 0.5em
      margin-left: 1em

  .caption
    color: #64748B
    display: block
    font-size: 0.9em
    margin-top: 0.5em
    position: relative
    text-align: center

  .video-container
    position: relative
    padding-top: (9 / 16 * 100)%
    height: 0
    overflow: hidden
    iframe, object, embed
      position: absolute
      top: 0
      left: 0
      width: 100%
      height: 100%
      margin-top: 0

  pre, code
    font-family: font-mono

// ===============
// Read More Button
// ===============
.article-more-link a
  display: inline-block
  line-height: 1em
  padding: 8px 20px
  border-radius: 20px
  background: rgba(148, 163, 184, 0.10)
  color: #CBD5E1
  text-decoration: none
  border: 1px solid rgba(148, 163, 184, 0.20)
  transition: all 0.25s ease
  &:hover
    background: rgba(59, 130, 246, 0.18)
    color: #F8FAFC
    text-decoration: none
    border-color: rgba(96, 165, 250, 0.35)
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.16)

// ===============
// Article Footer
// ===============
.article-footer
  clearfix()
  font-size: 0.85em
  line-height: line-height
  border-top: 1px solid rgba(255, 255, 255, 0.06)
  padding-top: line-height
  margin: 0 article-padding article-padding
  a
    color: #94A3B8
    text-decoration: none
    transition: color 0.2s ease
    &:hover
      color: #F8FAFC

// Tag chips in article footer
.article-tag-list
  display: flex
  flex-wrap: wrap
  gap: 8px
  list-style: none
  margin: 0
  padding: 0

.article-tag-list-item
  float: none
  margin: 0

.article-tag-list
  gap: 7px

.article-tag-list-link
  display: inline-flex
  align-items: center
  padding: 3px 10px
  border-radius: 999px
  background: rgba(148, 163, 184, 0.08)
  border: 1px solid rgba(148, 163, 184, 0.15)
  font-size: 0.73em
  color: #94A3B8
  text-decoration: none
  line-height: 1.4
  letter-spacing: 0.2px
  transition: all 0.2s ease
  &:before
    content: none
  &:hover
    background: rgba(59, 130, 246, 0.12)
    border-color: rgba(96, 165, 250, 0.3)
    color: #93C5FD
    text-decoration: none

.article-comment-link
  float: right
  &:before
    padding-right: 8px

.article-share-link
  cursor: pointer
  float: right
  margin-left: 20px
  &:before
    padding-right: 6px

// ===============
// Article Nav (Prev / Next)
// ===============
#article-nav
  clearfix()
  position: relative
  @media mq-normal
    margin: block-margin 0
    &:before
      absolute-center(8px)
      content: ""
      border-radius: 50%
      background: rgba(255, 255, 255, 0.08)

.article-nav-link-wrap
  text-decoration: none
  color: #94A3B8
  box-sizing: border-box
  margin-top: block-margin
  text-align: center
  display: block
  transition: color 0.2s ease
  &:hover
    color: #F8FAFC
  @media mq-normal
    width: 50%
    margin-top: 0

#article-nav-newer
  @media mq-normal
    float: left
    text-align: right
    padding-right: 20px

#article-nav-older
  @media mq-normal
    float: right
    text-align: left
    padding-left: 20px

.article-nav-caption
  text-transform: uppercase
  letter-spacing: 2px
  color: #64748B
  line-height: 1em
  font-weight: 600
  #article-nav-newer &
    margin-right: -2px

.article-nav-title
  font-size: 0.85em
  line-height: line-height
  margin-top: 0.5em

// ===============
// Share Box — Liquid Glass
// ===============
.article-share-box
  position: absolute
  display: none
  background: linear-gradient(135deg, rgba(30, 41, 59, 0.97), rgba(30, 41, 59, 0.92))
  backdrop-filter: blur(20px) saturate(180%)
  -webkit-backdrop-filter: blur(20px) saturate(180%)
  border: 1px solid rgba(148, 163, 184, 0.22)
  border-radius: 14px
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.06),
    0 16px 48px rgba(15, 23, 42, 0.5)
  margin-left: -145px
  overflow: hidden
  z-index: 1
  &.on
    display: block

.article-share-input
  width: 100%
  background: none
  box-sizing: border-box
  font: 14px font-sans
  padding: 0 15px
  color: #F8FAFC
  outline: none
  border: 1px solid rgba(148, 163, 184, 0.15)
  border-radius: 14px 14px 0 0
  height: 36px
  line-height: 36px

.article-share-links
  clearfix()
  background: rgba(148, 163, 184, 0.04)

$article-share-link
  width: 50px
  height: 36px
  display: block
  float: left
  position: relative
  color: #64748B
  .fa
    font-size: 20px
    absolute-center(@font-size)
    text-align: center
  &:hover
    color: #fff

.article-share-twitter
  @extend $article-share-link
  &:hover
    background: color-twitter

.article-share-facebook
  @extend $article-share-link
  &:hover
    background: color-facebook

.article-share-pinterest
  @extend $article-share-link
  &:hover
    background: color-pinterest

.article-share-linkedin
  @extend $article-share-link
  &:hover
    background: color-linkedin

.article-gallery
  background: #000
  position: relative

.article-gallery-photos
  position: relative
  overflow: hidden

.article-gallery-img
  display: none
  max-width: 100%
  &:first-child
    display: block
  &.loaded
    position: absolute
    display: block
  img
    display: block
    max-width: 100%
    margin: 0 auto
