@import "nib"
@import "_variables"
@import "_util/mixin"
@import "_util/grid"

global-reset()

input, button
  margin: 0
  padding: 0
  &::-moz-focus-inner
    border: 0
    padding: 0

html, body, #container
  min-height: 100vh

html
  box-sizing: border-box

*, *:before, *:after
  box-sizing: inherit

// ===============
// Deep Space Background — Brighter Blue-Gray Edition
// ===============
body
  background:
    radial-gradient(circle at 15% 5%, rgba(59, 130, 246, 0.16), transparent 34%),
    radial-gradient(circle at 85% 15%, rgba(139, 92, 246, 0.14), transparent 32%),
    radial-gradient(circle at 50% 70%, rgba(59, 130, 246, 0.06), transparent 40%),
    linear-gradient(180deg, #111C2E 0%, #0F172A 48%, #111827 100%)
  background-attachment: fixed
  font: font-size font-sans
  -webkit-text-size-adjust: 100%
  color: color-text-primary

// Subtle star-dust texture overlay — slightly brighter
body::before
  content: ""
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100%
  pointer-events: none
  z-index: 0
  background-image:
    radial-gradient(1px 1px at 10% 15%, rgba(255, 255, 255, 0.35), transparent),
    radial-gradient(1px 1px at 25% 35%, rgba(255, 255, 255, 0.28), transparent),
    radial-gradient(1.5px 1.5px at 40% 8%, rgba(255, 255, 255, 0.38), transparent),
    radial-gradient(1px 1px at 55% 45%, rgba(255, 255, 255, 0.22), transparent),
    radial-gradient(1px 1px at 70% 22%, rgba(255, 255, 255, 0.28), transparent),
    radial-gradient(1.5px 1.5px at 85% 55%, rgba(255, 255, 255, 0.32), transparent),
    radial-gradient(1px 1px at 15% 65%, rgba(255, 255, 255, 0.22), transparent),
    radial-gradient(1px 1px at 60% 75%, rgba(255, 255, 255, 0.25), transparent),
    radial-gradient(1px 1px at 90% 85%, rgba(255, 255, 255, 0.2), transparent),
    radial-gradient(1.5px 1.5px at 35% 88%, rgba(255, 255, 255, 0.25), transparent),
    radial-gradient(1px 1px at 48% 12%, rgba(255, 255, 255, 0.22), transparent),
    radial-gradient(1px 1px at 78% 68%, rgba(255, 255, 255, 0.28), transparent)

// ===============
// Hero Section
// ===============
#hero
  position: relative
  display: flex
  align-items: center
  justify-content: center
  text-align: center
  padding: 90px 20px 68px
  overflow: hidden
  margin-bottom: 10px

.hero-bg
  position: absolute
  inset: 0
  pointer-events: none
  // Hero image layer — low opacity to preserve text contrast
  &::before
    content: ""
    position: absolute
    inset: 0
    background: url('/assets/images/backgrounds/hero-bg.webp') center/cover no-repeat
    opacity: 0.28
  // CSS gradient overlays — brighter blue-purple glow
  &::after
    content: ""
    position: absolute
    inset: 0
    background:
      radial-gradient(circle at 50% 0%, rgba(59, 130, 246, 0.22), transparent 34%),
      radial-gradient(circle at 85% 20%, rgba(139, 92, 246, 0.16), transparent 30%),
      radial-gradient(ellipse 50% 40% at 50% 80%, rgba(59, 130, 246, 0.08), transparent 50%)

.hero-content
  position: relative
  z-index: 1
  max-width: 700px

.hero-title
  font-size: 3.8em
  font-weight: 800
  letter-spacing: 8px
  color: #F8FAFC
  margin: 0 0 20px
  line-height: 1.05
  text-shadow:
    0 0 80px rgba(59, 130, 246, 0.3),
    0 0 160px rgba(139, 92, 246, 0.16),
    0 1px 0 rgba(255, 255, 255, 0.12)

.hero-subtitle
  font-size: 1.35em
  font-weight: 300
  letter-spacing: 4px
  color: #CBD5E1
  margin: 0 0 14px
  line-height: 1.4

.hero-desc
  font-size: 1em
  font-weight: 400
  letter-spacing: 2.5px
  color: #E2E8F0
  margin: 0 0 44px
  line-height: 1.5

.hero-actions
  display: flex
  gap: 16px
  justify-content: center
  flex-wrap: wrap

.hero-btn
  display: inline-block
  padding: 13px 34px
  border-radius: 28px
  font-size: 0.95em
  font-weight: 500
  letter-spacing: 0.8px
  text-decoration: none
  transition: all 0.3s ease
  cursor: pointer
  backdrop-filter: blur(12px) saturate(180%)
  -webkit-backdrop-filter: blur(12px) saturate(180%)

.hero-btn-primary
  background: linear-gradient(135deg, #60A5FA, #8B5CF6)
  border: 1px solid rgba(147, 197, 253, 0.35)
  color: #FFFFFF
  box-shadow: 0 12px 34px rgba(59, 130, 246, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.18)
  &:hover
    background: linear-gradient(135deg, #93C5FD, #A78BFA)
    border-color: rgba(147, 197, 253, 0.5)
    box-shadow:
      0 18px 44px rgba(59, 130, 246, 0.36),
      inset 0 1px 0 rgba(255, 255, 255, 0.22)
    color: #fff
    text-decoration: none

.hero-btn-secondary
  background: rgba(255, 255, 255, 0.08)
  border: 1px solid rgba(203, 213, 225, 0.28)
  color: #F8FAFC
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1)
  &:hover
    background: rgba(255, 255, 255, 0.14)
    border-color: rgba(203, 213, 225, 0.4)
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 0 28px rgba(255, 255, 255, 0.08)
    color: #fff
    text-decoration: none

// Mobile hero adjustments
@media (max-width: 768px)
  #hero
    padding: 72px 20px 72px
    min-height: auto

  .hero-title
    font-size: clamp(36px, 10vw, 56px)
    letter-spacing: 0.06em
    margin-bottom: 16px

  .hero-subtitle
    font-size: 1em
    letter-spacing: 2px
    max-width: 320px
    margin-left: auto
    margin-right: auto

  .hero-desc
    font-size: 15px
    line-height: 1.8
    letter-spacing: 0.03em
    max-width: 320px
    margin-left: auto
    margin-right: auto

  .hero-actions
    flex-direction: column
    align-items: center
    gap: 14px

  .hero-btn
    width: min(100%, 320px)
    height: 52px
    font-size: 15px
    border-radius: 999px
    display: flex
    align-items: center
    justify-content: center
    text-align: center

// Homepage full-width main
body.home #main
  @media mq-normal
    column(columns)

// Section headers — bilingual
.section-header
  display: flex
  align-items: baseline
  gap: 12px
  margin: 0 0 24px
  padding: 0 4px

.section-label
  font-size: 0.72em
  font-weight: 600
  letter-spacing: 3.5px
  text-transform: uppercase
  color: #64748B
  margin: 0

.section-sub
  font-size: 0.7em
  font-weight: 400
  color: #475569
  letter-spacing: 1px

// Content hub cards
.content-cards-section
  margin: 0 0 36px

.content-cards-grid
  display: grid
  grid-template-columns: repeat(4, 1fr)
  gap: 14px
  @media (max-width: 768px)
    grid-template-columns: 1fr
    gap: 16px

.content-card
  display: flex
  flex-direction: column
  border-radius: 18px
  background: linear-gradient(135deg, rgba(30, 41, 59, 0.66), rgba(30, 41, 59, 0.42))
  backdrop-filter: blur(16px) saturate(180%)
  -webkit-backdrop-filter: blur(16px) saturate(180%)
  border: 1px solid rgba(148, 163, 184, 0.20)
  text-decoration: none
  overflow: hidden
  transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease
  &:hover
    transform: translateY(-2px)
    border-color: rgba(147, 197, 253, 0.36)
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 18px 50px rgba(15, 23, 42, 0.4),
      0 0 36px rgba(59, 130, 246, 0.1)
    text-decoration: none

// Cover image strip at top of card
.content-card-cover
  height: 72px
  background-size: cover
  background-position: center 30%
  position: relative
  flex-shrink: 0
  // Dark gradient overlay — keeps text readable, preserves mood
  &::after
    content: ""
    position: absolute
    inset: 0
    background: linear-gradient(to bottom, rgba(15, 23, 42, 0.35), rgba(15, 23, 42, 0.6))
    pointer-events: none

// Card body — symbol + text row
.content-card-body
  display: flex
  align-items: flex-start
  gap: 12px
  padding: 16px 18px

.content-card-symbol
  font-size: 1.1em
  line-height: 1
  flex-shrink: 0
  opacity: 0.5
  transition: opacity 0.3s ease

.content-card:hover .content-card-symbol
  opacity: 0.8

.content-card-text
  min-width: 0

.content-card-title
  font-size: 0.88em
  font-weight: 600
  color: #F1F5F9
  margin: 0 0 3px
  line-height: 1.3
  letter-spacing: 0.3px

.content-card-desc
  font-size: 0.76em
  color: #94A3B8
  margin: 0
  line-height: 1.45

// Post list cards
.post-list-section
  margin: 0 0 50px

.post-list-grid
  display: flex
  flex-direction: column
  gap: 18px

.post-card-inner
  padding: 22px 26px
  border-radius: 18px
  background: linear-gradient(135deg, rgba(30, 41, 59, 0.66), rgba(30, 41, 59, 0.42))
  backdrop-filter: blur(16px) saturate(180%)
  -webkit-backdrop-filter: blur(16px) saturate(180%)
  border: 1px solid rgba(148, 163, 184, 0.20)
  overflow: hidden
  transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, background 0.3s ease
  box-shadow: 0 18px 50px rgba(15, 23, 42, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.04)

// Card with cover image — remove top padding, cover sits flush at top
.post-card-inner.has-cover
  padding-top: 0

// Cover image strip — 16:9, dark overlay
.post-card-cover
  position: relative
  margin: 0 -26px 18px  // negative side margins to reach card edges
  aspect-ratio: 16 / 9
  overflow: hidden
  background: #111C2E
  img
    width: 100%
    height: 100%
    object-fit: cover
    display: block
    opacity: 0.6
    transition: opacity 0.35s ease, transform 0.35s ease
  // Dark gradient overlay — bottom fades into card body
  &::after
    content: ""
    position: absolute
    inset: 0
    background: linear-gradient(to bottom, rgba(15, 23, 42, 0.1), rgba(15, 23, 42, 0.65))
    pointer-events: none

.post-card:hover .post-card-cover img
  opacity: 0.65
  transform: scale(1.03)

// Mobile: cover becomes narrower
@media (max-width: 768px)
  .post-card-cover
    margin: 0 -18px 14px
    aspect-ratio: 16 / 9

.post-card:hover .post-card-inner
  transform: translateY(-2px)
  background: linear-gradient(135deg, rgba(39, 52, 75, 0.74), rgba(39, 52, 75, 0.52))
  border-color: rgba(147, 197, 253, 0.36)
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.06),
    0 24px 70px rgba(15, 23, 42, 0.42),
    0 0 36px rgba(59, 130, 246, 0.12)

.post-card-date
  display: inline-block
  font-size: 0.73em
  font-weight: 500
  letter-spacing: 0.5px
  color: #64748B
  text-decoration: none
  margin-bottom: 8px
  transition: color 0.2s ease
  &:hover
    color: #94A3B8

.post-card-title
  font-size: 1.18em
  font-weight: 700
  line-height: 1.3
  margin: 0 0 8px
  letter-spacing: -0.01em
  a
    color: #F1F5F9
    text-decoration: none
    transition: color 0.2s ease
    &:hover
      color: #60A5FA

.post-card-excerpt
  font-size: 0.88em
  line-height: 1.7
  color: #CBD5E1
  margin: 0 0 14px

.post-card-tags
  display: flex
  flex-wrap: wrap
  gap: 7px
  margin-bottom: 16px

.tag-chip
  display: inline-flex
  align-items: center
  padding: 3px 10px
  border-radius: 999px
  background: rgba(148, 163, 184, 0.08)
  border: 1px solid rgba(148, 163, 184, 0.15)
  font-size: 0.73em
  color: #94A3B8
  text-decoration: none
  line-height: 1.4
  transition: all 0.2s ease
  letter-spacing: 0.2px
  &:hover
    background: rgba(59, 130, 246, 0.12)
    border-color: rgba(96, 165, 250, 0.3)
    color: #93C5FD
    text-decoration: none

.post-card-more
  display: inline-block
  font-size: 0.8em
  font-weight: 500
  color: #94A3B8
  text-decoration: none
  letter-spacing: 0.3px
  transition: color 0.2s ease
  &:hover
    color: #93C5FD

.outer
  clearfix()
  max-width: (column-width + gutter-width) * columns + gutter-width
  margin: 0 auto
  padding: 0 gutter-width

.inner
  column(columns)

.left, .alignleft
  float: left

.right, .alignright
  float: right

.clear
  clear: both

#container
  position: relative

#wrap
  min-height: 100vh
  width: 100%
  position: relative
  top: 0
  left: 0
  z-index: 1
  background: transparent

if sidebar and sidebar isnt bottom
  #main
    @media mq-normal
      column(main-column)

if sidebar is left
  @media mq-normal
    #main
      float: right

@import "_extend"
@import "_partial/header"
@import "_partial/article"
@import "_partial/comment"
@import "_partial/archive"
@import "_partial/footer"
@import "_partial/highlight"
@import "_partial/mobile"

if sidebar
  @import "_partial/sidebar"

// ===============
// Comprehensive Mobile Overrides (≤768px)
// ===============
@media (max-width: 768px)
  // Prevent horizontal overflow
  html, body
    overflow-x: hidden
    max-width: 100vw

  #container, #wrap, #main
    max-width: 100vw
    overflow-x: hidden

  // Outer padding reduction
  .outer
    padding: 0 16px

  // Section headers
  .section-header
    gap: 8px
    margin-bottom: 18px

  .section-label
    font-size: 12px
    letter-spacing: 3px

  .section-sub
    font-size: 11px

  // Content cards
  .content-card
    border-radius: 22px

    background: rgba(30, 41, 59, 0.72)
  .content-card-cover
    height: 140px

  .content-card-body
    padding: 18px

  .content-card-title
    font-size: 20px

  .content-card-desc
    font-size: 14px

  // Post cards
  .post-card-inner
    padding: 18px 20px
    background: rgba(30, 41, 59, 0.72)

  .post-card-inner.has-cover
    padding-top: 0

  .post-card-title
    font-size: 1.05em

  .post-card-excerpt
    font-size: 0.84em

  // Pagination
  #page-nav
    padding: 0 16px

  // Article/page inner
  .article-inner
    padding: 20px

  // Archive
  .archives-wrap
    padding: 0

  .archive-article-inner
    padding: 14px 16px
