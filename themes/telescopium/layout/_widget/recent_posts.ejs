<% if (site.posts.length){ %>
  <div class="widget-wrap">
    <h3 class="widget-title"><%= __('recent_posts') %></h3>
    <div class="widget widget-recent">
      <ul class="recent-posts-list">
        <% site.posts.sort('date', -1).limit(theme.recent_posts_limits).each(function(post){ %>
          <li class="recent-posts-item">
            <a href="<%- url_for(post.path) %>" class="recent-posts-title"><%= post.title %></a>
            <span class="recent-posts-date"><%= date(post.date, 'YYYY · MM · DD') %></span>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
<% } %>